# SQLite database (libsql). Default: file:./dev.db
DATABASE_URL=file:./dev.db

# OpenAI-compatible API key (required for AI scoring and cover letters).
# Without this the app falls back to local keyword-based scoring.
OPENAI_API_KEY=sk-...

# Optional: custom base URL for a compatible provider (e.g. Azure, local proxy)
OPENAI_BASE_URL=

# Set to "1" to launch Playwright in headful mode (useful for debugging crawlers)
PLAYWRIGHT_HEADFUL=0
